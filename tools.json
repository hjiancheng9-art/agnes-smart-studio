{
  "_comment": "Agnes Smart Studio 工具配置 — 智能体模式下自动加载",
  "tools": [
    {
      "name": "read_file",
      "type": "python",
      "description": "读取文本文件内容，返回带行号。大文件用 offset(起始行)和 limit(最大行数)分段读取。改文件前先用此工具确认内容。",
      "function": "core.file_tools.read_file",
      "parameters": {
        "path": {
          "type": "string",
          "description": "文件路径",
          "required": true
        },
        "offset": {
          "type": "integer",
          "description": "从第几行开始读（0=开头，默认0）",
          "required": false
        },
        "limit": {
          "type": "integer",
          "description": "最多读多少行（0=全部，默认0=最多500行）",
          "required": false
        }
      }
    },
    {
      "name": "write_file",
      "type": "python",
      "description": "创建新文件或完全覆盖已有文件。UTF-8 编码。参数: path=文件路径, content=完整文件内容。会覆盖整个文件，不是追加。支持任意字符。",
      "function": "core.file_tools.write_file",
      "parameters": {
        "path": {
          "type": "string",
          "description": "文件路径",
          "required": true
        },
        "content": {
          "type": "string",
          "description": "要写入的内容",
          "required": true
        }
      }
    },
    {
      "name": "edit_file",
      "type": "python",
      "description": "替换文件中的一段文本。参数: path=文件路径, old_text=要替换的原文本（必须和文件中一字不差含缩进）, new_text=新文本。只替换第一个匹配。先用 read_file 确认原文本内容再调用此工具。",
      "function": "core.file_tools.edit_file",
      "parameters": {
        "path": {
          "type": "string",
          "description": "文件路径",
          "required": true
        },
        "old_text": {
          "type": "string",
          "description": "要替换的原始文本（必须精确匹配，包括缩进）",
          "required": true
        },
        "new_text": {
          "type": "string",
          "description": "替换后的新文本",
          "required": true
        }
      }
    },
    {
      "name": "search_files",
      "type": "python",
      "description": "在项目中搜索代码/文本（支持正则表达式）。返回格式: 文件路径:行号:匹配行。搜 .py .js .ts .md .json 等代码文件。pattern 参数接受 Python 正则语法。",
      "parameters": {
        "pattern": {
          "type": "string",
          "description": "Regular expression search pattern",
          "required": true
        }
      },
      "function": "core.file_tools.search_files"
    },
    {
      "name": "glob_files",
      "type": "python",
      "description": "按文件名模式搜索文件（支持 glob 通配符，如 **/*.py, src/**/*.ts）。返回匹配的文件路径列表。",
      "function": "core.file_tools.glob_files",
      "parameters": {
        "pattern": {
          "type": "string",
          "description": "glob 文件名模式，如 **/*.py",
          "required": true
        }
      }
    },
    {
      "name": "list_files",
      "type": "python",
      "description": "列出目录下的文件和子目录（含文件大小）。可递归列出。",
      "parameters": {
        "path": {
          "type": "string",
          "description": "Directory path (default: .)",
          "required": false
        }
      },
      "function": "core.file_tools.list_files"
    },
    {
      "name": "think_deep",
      "type": "python",
      "description": "用本地重型模型做深度推理（代码分析/架构审查/方案设计）。需 llama-server 在 8080 端口。不调工具，纯文本推理。",
      "function": "core.file_tools.think_deep",
      "parameters": {
        "prompt": {
          "type": "string",
          "description": "推理任务描述，越详细越好",
          "required": true
        },
        "max_tokens": {
          "type": "integer",
          "description": "最大回复长度，默认2000",
          "required": false
        }
      }
    },
    {
      "name": "run_python",
      "type": "python",
      "description": "执行 Python 代码并返回结果。直接进程内 exec，永不丢输出。仅用于简单代码；复杂代码先用 write_file 写 .py 文件再 run_bash 执行。",
      "function": "core.file_tools.run_python",
      "parameters": {
        "code": {
          "type": "string",
          "description": "Python 代码",
          "required": true
        }
      }
    },
